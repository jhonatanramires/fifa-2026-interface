---
import type { Config } from "../lib/config-loader"
import { Icon } from "astro-icon/components"

interface Props {
  configs?: Config
}
const { configs } = Astro.props
---

<footer class="panini-footer">
  <div class="footer-container">

    <!-- Columna 1: Información de la tienda -->
    <div class="footer-column">
      <h3>Tu Distribuidor Panini</h3>
      <li><a href="about">¿Quiénes somos?</a></li>
      <p>Somos distribuidores oficiales de los álbumes, cajas y colecciones más exclusivas de Panini. ¡La historia que se pega para siempre!</p>
      {configs?.DIR && (
        <p>
          <Icon name="fa6-solid:location-dot" aria-hidden="true" />
          {configs.DIR}
        </p>
      )}
      {configs?.EMAIL && (
        <p>
          <Icon name="fa6-solid:envelope" aria-hidden="true" />
          {configs.EMAIL}
        </p>
      )}
    </div>

    <!-- Columna 2: Descripción corta -->
    <div class="footer-column">
      <h3>Completa tu Álbum Panini FIFA World Cup 2026™</h3>
      <p>Vive la emoción del Mundial 2026 y completa tu colección oficial Panini. Encuentra todo lo que necesitas para llenar tu álbum: cajas Panini Mundial 2026, displays de sobres, álbum Panini FIFA 2026 pasta dura azul y la exclusiva edición Álbum Panini Gold pasta dura.</p>
    </div>

    <!-- Columna 3: Redes Sociales -->
    <div class="footer-column">
      <h3>Síguenos</h3>
      <p>Enterate de todas las novedades y lanzamientos en tiempo real.</p>
      <div class="social-links">
        {configs?.FACEBOOK && (
          <a href={configs.FACEBOOK} aria-label="Facebook" class="social-link social-link--facebook">
            <Icon name="fa6-brands:facebook-f" />
          </a>
        )}
        {configs?.INSTAGRAM && (
          <a href={configs.INSTAGRAM} aria-label="Instagram" class="social-link social-link--instagram">
            <Icon name="fa6-brands:instagram" />
          </a>
        )}
        {configs?.YOUTUBE && (
          <a href={configs.YOUTUBE} aria-label="YouTube" class="social-link social-link--youtube">
            <Icon name="fa6-brands:youtube" />
          </a>
        )}
        {configs?.TWITTER && (
          <a href={configs.TWITTER} aria-label="X/Twitter" class="social-link social-link--twitter">
            <Icon name="fa6-brands:x-twitter" />
          </a>
        )}
        {configs?.TIKTOK && (
          <a href={configs.TIKTOK} aria-label="TikTok" class="social-link social-link--tiktok">
            <Icon name="fa6-brands:tiktok" />
          </a>
        )}
      </div>
    </div>

  </div>

  <!-- Derechos de autor -->
  <div class="footer-bottom">
    <p>&copy; {new Date().getFullYear()} Tu Distribuidor Panini. Todos los derechos reservados.
      <br><span style="font-size: 0.7rem; opacity: 0.7;">Este sitio opera como distribuidor independiente de productos Panini.</span>
    </p>
    <p style="margin-top: 12px; font-size: 0.75rem; opacity: 0.8;">
      Desarrollado y gestionado por
      <a href="https://jhorodriguezra.onrender.com/" target="_blank" rel="noopener noreferrer" class="footer-link">
        Niusoft
      </a>
      · <a href="mailto:adm.jhonatanramires@gmail.com" class="footer-link">Contactar</a>
    </p>
  </div>
</footer>

<style>
  .panini-footer {
    --panini-orange: #F58A1E;
    --panini-yellow: #FFCE00;
    --panini-blue-dark: #003865;
    --panini-red: #E2231A;
    --text-light: #f5f5f5;
    --text-muted: #b0c4de;

    background-color: var(--panini-blue-dark);
    color: var(--text-light);
    padding: 50px 20px 20px;
    border-top: 5px solid var(--panini-orange);
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 40px;
  }

  .footer-column {
    flex: 1;
    min-width: 220px;
  }

  .footer-column h3 {
    color: var(--panini-yellow);
    font-size: 1.1rem;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .footer-column p {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    line-height: 1.6;
    font-size: 0.95rem;
    margin-bottom: 15px;
  }

  .footer-column ul {
    list-style: none;
    padding: 0;
  }

  .footer-column ul li {
    margin-bottom: 10px;
  }

  .footer-column ul li a,
  .footer-column > a {
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.3s ease;
    font-size: 0.95rem;
    display: inline-block;
    margin-bottom: 10px;
  }

  .footer-column ul li a:hover,
  .footer-column > a:hover {
    color: var(--panini-orange);
    padding-left: 5px;
  }

  /* --- Iconos de texto (DIR, EMAIL) --- */
  .footer-column p [data-icon] {
    width: 1em;
    height: 1em;
    fill: currentColor;
    flex-shrink: 0;
    color: var(--panini-orange);
  }

  /* --- Redes Sociales --- */
  .social-links {
    display: flex;
    gap: 15px;
    margin-top: 15px;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    color: var(--text-light);
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .social-link [data-icon] {
    width: 1.1em;
    height: 1.1em;
    fill: currentColor;
  }

  .social-link:hover {
    transform: translateY(-3px);
    background-color: white;
  }

  .social-link--facebook:hover  { color: #1877F2; }
  .social-link--instagram:hover { color: #E1306C; }
  .social-link--youtube:hover   { color: #FF0000; }
  .social-link--twitter:hover   { color: #000000; }
  .social-link--tiktok:hover    { color: #010101; }

  /* --- Copyright --- */
  .footer-bottom {
    max-width: 1200px;
    margin: 30px auto 0;
    padding-top: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .footer-link {
    color: var(--panini-orange);
    text-decoration: none;
    font-weight: bold;
  }

  .footer-link:hover {
    text-decoration: underline;
  }

  /* --- Responsive --- */
  @media (max-width: 768px) {
    .footer-container {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .footer-column {
      min-width: 100%;
    }
    .footer-column p {
      justify-content: center;
    }
    .social-links {
      justify-content: center;
    }
  }
</style>