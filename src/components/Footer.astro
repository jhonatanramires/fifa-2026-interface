---
import type { Config } from "../lib/config-loader"
interface Props {
  configs?: Config
}
const { configs } = Astro.props
---

<footer class="panini-footer">
  <div class="footer-container">
    
    <!-- Columna 1: Información de la tienda -->
    <div class="footer-column">
      <h3>Tu Distribuidor Panini</h3>
      <li><a href="about">¿Quiénes somos?</a></li>
      <p>Somos distribuidores oficiales de los álbumes, cajas y colecciones más exclusivas de Panini. ¡La historia que se pega para siempre!</p>
      <p style={`display: ${configs?.DIR ? "" : "none"}`} ><i class="fas fa-map-marker-alt"></i> {configs?.DIR ?? "#"}</p>
      <p style={`display: ${configs?.EMAIL ? "" : "none"}`} ><i class="fas fa-envelope"></i> {configs?.EMAIL ?? "#"}</p>
    </div>

    <!-- Columna 2: Descripción corta -->
    <div class="footer-column">
      <h3>Completa tu Álbum Panini FIFA World Cup 2026™</h3>
      <p>Vive la emoción del Mundial 2026 y completa tu colección oficial Panini. Encuentra todo lo que necesitas para llenar tu álbum: cajas Panini Mundial 2026, displays de sobres, álbum Panini FIFA 2026 pasta dura azul y la exclusiva edición Álbum Panini Gold pasta dura.</p>
    </div>

    <!-- Columna 3: Enlaces Rápidos
    <div class="footer-column">
      <h3>Enlaces Rápidos</h3>
      <ul>
        <li><a href="#">Álbumes y Colecciones</a></li>
        <li><a href="#">Cajas y Sobres</a></li>
        <li><a href="#">Próximos Lanzamientos</a></li>
        <li><a href="#">Contacto y Ayuda</a></li>
      </ul>
    </div> -->

    <!-- Columna 3: Redes Sociales -->
    <div class="footer-column">
      <h3>Síguenos</h3>
      <p>Enterate de todas las novedades y lanzamientos en tiempo real.</p>
      <div class="social-links">
        <!-- Reemplaza los '#' con tus URLs reales -->
        <a href={configs?.FACEBOOK ?? "#"} style={`display: ${configs?.FACEBOOK ? "" : "none"}`} class="fab fa-facebook-f" aria-label="Facebook"></a>
        <a href={configs?.INSTAGRAM ?? "#"} style={`display: ${configs?.INSTAGRAM ? "" : "none"}`} class="fab fa-instagram" aria-label="Instagram"></a>
        <a href={configs?.YOUTUBE ?? "#"} style={`display: ${configs?.YOUTUBE ? "" : "none"}`} class="fab fa-youtube" aria-label="YouTube"></a>
        <a href={configs?.TWITTER ?? "#"} style={`display: ${configs?.TWITTER ? "" : "none"}`} class="fa-brands fa-twitter fab fa-x-twitter" aria-label="X/Twitter"></a>
        <a href={configs?.TIKTOK ?? "#"} style={`display: ${configs?.TIKTOK ? "" : "none"}`} class="fab fa-tiktok" aria-label="TikTok"></a>
      </div>
    </div>

  </div>

  <!-- Derechos de autor -->
  <div class="footer-bottom">
    <p>&copy; {new Date().getFullYear()} Tu Distribuidor Panini. Todos los derechos reservados. 
      <br><span style="font-size: 0.7rem; opacity: 0.7;">Este sitio opera como distribuidor independiente de productos Panini.</span>
    </p>
        <p style="margin-top: 12px; font-size: 0.75rem; opacity: 0.8;">
      Desarrollado y gestionado por 
      <a href={"https://jhorodriguezra.onrender.com/"} target="_blank" rel="noopener noreferrer" style="color: var(--panini-orange); text-decoration: none; font-weight: bold;">
        Niusoft
      </a>
      <!-- Contacto opcional que aparece solo si tienes configurado el email en tus configs -->
      <span>
         · <a href={`mailto:adm.jhonatanramires@gmail.com`} style="color: var(--panini-orange); text-decoration: none;">Contactar</a>
      </span>
    </p>
  </div>
</footer>

<style>
  /* NOTA: Asegúrate de tener importada la librería de FontAwesome 
     en el <head> de tu Layout.astro principal para que los iconos se vean. */
  
  .panini-footer {
    /* Variables de color propias del componente */
    --panini-orange: #F58A1E;
    --panini-yellow: #FFCE00;
    --panini-blue-dark: #003865;
    --panini-red: #E2231A;
    --text-light: #f5f5f5;
    --text-muted: #b0c4de;

    /* Estilos base del footer */
    background-color: var(--panini-blue-dark);
    color: var(--text-light);
    padding: 50px 20px 20px;
    border-top: 5px solid var(--panini-orange);
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 40px;
  }

  .footer-column {
    flex: 1;
    min-width: 220px;
  }

  .footer-column h3 {
    color: var(--panini-yellow);
    font-size: 1.1rem;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .footer-column p {
    color: var(--text-muted);
    line-height: 1.6;
    font-size: 0.95rem;
    margin-bottom: 15px;
  }

  .footer-column ul {
    list-style: none;
    padding: 0;
  }

  .footer-column ul li {
    margin-bottom: 10px;
  }

  .footer-column ul li a {
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.3s ease;
    font-size: 0.95rem;
  }

  .footer-column ul li a:hover {
    color: var(--panini-orange);
    padding-left: 5px;
  }

  /* REDES SOCIALES */
  .social-links {
    display: flex;
    gap: 15px;
    margin-top: 15px;
  }

  .social-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    color: var(--text-light);
    text-decoration: none;
    transition: all 0.3s ease;
  }

  /* Colores específicos al pasar el mouse */
  .social-links a:hover {
    transform: translateY(-3px);
    background-color: white;
  }
  .social-links a.fa-facebook-f:hover { color: #1877F2; }
  .social-links a.fa-instagram:hover { color: #E1306C; }
  .social-links a.fa-youtube:hover { color: #FF0000; }
  .social-links a.fa-x-twitter:hover { color: #000000; }
  .social-links a.fa-tiktok:hover { color: #010101; }

  /* COPYRIGHT */
  .footer-bottom {
    max-width: 1200px;
    margin: 30px auto 0;
    padding-top: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .footer-container {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .footer-column {
      min-width: 100%;
    }
    .social-links {
      justify-content: center;
    }
  }
</style>