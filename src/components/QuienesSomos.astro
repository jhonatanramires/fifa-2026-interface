---
// QuienesSomos.astro – Sección de historia y valores de la empresa
const valores = [
  {
    icono: "🎯",
    titulo: "Especialistas en Panini",
    texto: "Nos dedicamos exclusivamente a productos Panini. Eso nos permite conocerlos a fondo y asesorarte mejor que nadie.",
  },
  {
    icono: "✅",
    titulo: "Productos 100% originales",
    texto: "Solo vendemos productos oficiales con garantía de autenticidad. Sin imitaciones, sin sorpresas.",
  },
  {
    icono: "🚀",
    titulo: "Despacho a todo Colombia",
    texto: "Enviamos tu pedido desde Medellín a cualquier rincón del país, de forma rápida y segura.",
  },
  {
    icono: "🤝",
    titulo: "Atención personalizada",
    texto: "Te ayudamos a encontrar exactamente lo que necesitas para completar tu álbum o encontrar el regalo perfecto.",
  },
]
---

<section class="quienes-somos">
  <div class="section-inner">
    <div class="qs-grid">
      <!-- Columna texto -->
      <div class="qs-text">
        <span class="section-eyebrow">Sobre nosotros</span>
        <h2 class="section-title">Distribuidores Panini<br>en Medellín</h2>
        <p class="qs-p">
          Nacimos de la pasión por el fútbol y las colecciones Panini. Somos un equipo de aficionados que se convirtieron en distribuidores para que ningún coleccionista de Colombia se quedara sin su álbum.
        </p>
        <p class="qs-p">
          Desde Medellín atendemos a clientes en toda Colombia: coleccionistas individuales, grupos de intercambio, y padres que quieren el regalo perfecto para sus hijos. Panini FIFA World Cup 2026™ es nuestra colección más esperada y estamos listos para que la completes.
        </p>
        <div class="medellin-chip">
          <span class="chip-icon">📍</span>
          Medellín, Antioquia — Colombia
        </div>
      </div>

      <!-- Columna valores -->
      <div class="qs-valores">
        {valores.map((v) => (
          <div class="valor-card">
            <div class="valor-icon" aria-hidden="true">{v.icono}</div>
            <div>
              <p class="valor-titulo">{v.titulo}</p>
              <p class="valor-texto">{v.texto}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .quienes-somos {
    background: var(--panini-blue-dark);
    padding: 4rem 0;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .qs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .section-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--panini-blue);
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.15;
    margin: 0 0 1.25rem;
    letter-spacing: -0.02em;
  }

  .qs-p {
    font-size: 0.98rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.65);
    margin: 0 0 1rem;
  }

  .medellin-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.8);
    font-size: 0.82rem;
    font-weight: 600;
    padding: 0.45rem 1rem;
    border-radius: 999px;
    margin-top: 0.5rem;
  }

  .chip-icon {
    font-size: 1rem;
  }

  .qs-valores {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .valor-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 8px;
    padding: 1.1rem 1.25rem;
    transition: background 0.2s ease;
  }

  .valor-card:hover {
    background: rgba(255,255,255,0.09);
  }

  .valor-icon {
    font-size: 1.5rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .valor-titulo {
    font-size: 0.95rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.25rem;
    line-height: 1.3;
  }

  .valor-texto {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.55);
    margin: 0;
    line-height: 1.55;
  }

  @media (max-width: 768px) {
    .qs-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>