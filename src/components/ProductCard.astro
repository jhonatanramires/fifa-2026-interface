---
import { slugify } from '../lib/utils'
import type { Producto } from '../lib/productos-loader'
interface ProductCardProps extends Producto {
  
}

const { title, price, description, image_link, categories } = Astro.props

const priceFmt =
  price != null
    ? new Intl.NumberFormat("es-CO", {
        style: "currency",
        currency: "COP",
        maximumFractionDigits: 0,
      }).format(price)
    : "Consultar precio"

const href = `productos/${slugify(title)}`

---

<!-- article con position:relative para que el enlace absoluto se posicione dentro -->
<article 
  class="card" 
  data-product-categories={Array.isArray(categories) ? categories.join('|') : ''}
  style="position: relative;"
>
  <!-- Enlace overlay: ocupa todo el article y está por encima -->
  <a 
    href={href}
    style="position: absolute; inset: 0; z-index: 1; display: block;"
    aria-label={`Ver detalles de ${title}`}
  ></a>

  <div class="card-media">
    {
      image_link ? (
        <img src={image_link} alt={title} loading="lazy" />
      ) : (
        <span class="no-image">Sin imagen</span>
      )
    }
  </div>
<!-- 
  {shipping && <p class="despacho">{shipping}</p>} -->

  <div class="card-body">
    <h2 class="card-title text-pretty">{title}</h2>
    {description && <p class="card-desc text-pretty">{description}</p>}
    <p class="card-price">{priceFmt}</p>
  </div>
</article>