---
interface Props {
  nombre: string
  precio?: number | null
  descripcion?: string | null
  imagen?: string | null
  categorias?: string[]
  despacho?: string | null
}
const { nombre, precio, descripcion, imagen, categorias, despacho } = Astro.props

const precioFmt =
  precio != null
    ? new Intl.NumberFormat("es-CO", {
        style: "currency",
        currency: "COP",
        maximumFractionDigits: 0,
      }).format(precio)
    : "Consultar precio"
---

<article 
  class="card" 
  data-product-categories={Array.isArray(categorias) ? categorias.join('|') : ''}
>
  <div class="card-media">
    {
      imagen ? (
        <img src={imagen} alt={nombre} loading="lazy" />
      ) : (
        <span class="no-image">Sin imagen</span>
      )
    }
    <!-- <button class="add-btn" type="button" aria-label={`Agregar ${nombre} al carrito`}>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="9" cy="21" r="1"></circle>
        <circle cx="20" cy="21" r="1"></circle>
        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        <line x1="12" y1="8" x2="12" y2="14"></line>
        <line x1="9" y1="11" x2="15" y2="11"></line>
      </svg>
    </button> -->
  </div>

  {despacho && <p class="despacho">{despacho}</p>}

  <div class="card-body">
    <h2 class="card-title text-pretty">{nombre}</h2>
    {descripcion && <p class="card-desc text-pretty">{descripcion}</p>}
    <p class="card-price">{precioFmt}</p>
  </div>
</article>
