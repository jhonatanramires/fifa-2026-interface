---
import { slugify } from '../lib/utils'
// Agregamos la prop href (obligatoria)
interface Props {
  nombre: string
  precio?: number | null
  descripcion?: string | null
  imagen?: string | null
  categorias?: string[]
  despacho?: string | null
}

const { nombre, precio, descripcion, imagen, categorias, despacho } = Astro.props

const precioFmt =
  precio != null
    ? new Intl.NumberFormat("es-CO", {
        style: "currency",
        currency: "COP",
        maximumFractionDigits: 0,
      }).format(precio)
    : "Consultar precio"

const href = `productos/${slugify(nombre)}`

---

<!-- article con position:relative para que el enlace absoluto se posicione dentro -->
<article 
  class="card" 
  data-product-categories={Array.isArray(categorias) ? categorias.join('|') : ''}
  style="position: relative;"
>
  <!-- Enlace overlay: ocupa todo el article y está por encima -->
  <a 
    href={href}
    style="position: absolute; inset: 0; z-index: 1; display: block;"
    aria-label={`Ver detalles de ${nombre}`}
  ></a>

  <div class="card-media">
    {
      imagen ? (
        <img src={imagen} alt={nombre} loading="lazy" />
      ) : (
        <span class="no-image">Sin imagen</span>
      )
    }
  </div>

  {despacho && <p class="despacho">{despacho}</p>}

  <div class="card-body">
    <h2 class="card-title text-pretty">{nombre}</h2>
    {descripcion && <p class="card-desc text-pretty">{descripcion}</p>}
    <p class="card-price">{precioFmt}</p>
  </div>
</article>