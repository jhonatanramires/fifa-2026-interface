---
// about.astro — Página "Acerca de nosotros"
import { getCollection } from "astro:content"
import Layout from "../layouts/Layout.astro"
import HeroAbout from "../components/HeroAbout.astro"
import QuienesSomos from "../components/QuienesSomos.astro"
import ProductosAbout from "../components/ProductosAbout.astro"
import Resenas from "../components/Resenas.astro"
import type { Config } from "../lib/config-loader"

let configs: Config = {} as Config
let loadError: string | null = null
try {
  const config = await getCollection("configuraciones")
  configs = config[0]?.data as Config
} catch (err) {
  loadError = err instanceof Error ? err.message : "No se pudieron cargar las configuraciones."
}
---

<Layout configs={configs}>
  <HeroAbout />
  <QuienesSomos />
  <ProductosAbout />
  <Resenas />
</Layout>