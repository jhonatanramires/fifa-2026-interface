---
import { getCollection } from "astro:content"
import Layout from "../layouts/Layout.astro"
import CategoryTabs from "../components/CategoryTabs.astro"
import ProductCard from "../components/ProductCard.astro"
import type { Config } from "../lib/config-loader"

const DEFAULT_CATEGORIES = [
  "MUNDIAL",
  "ÚLTIMOS LANZAMIENTOS",
]

let productos: any[] = []
let configs: Config = {} as Config
let configError: string | null = null
let productosError: string | null = null

try {
  const config = await getCollection("configuraciones")
  configs = config[0]?.data as Config
} catch (err) {
  configError = err instanceof Error ? err.message : "No se pudieron cargar las configuraciones."
}

try {
  const entries = await getCollection("productos")
  productos = entries.map((e) => e.data)
} catch (err) {
  productosError = err instanceof Error ? err.message : "No se pudieron cargar los productos."
}

const sheetCategories = Array.from(
  new Set(
    productos
      .flatMap((p) => p.categories ?? [])
      .map((cat: string) => cat.trim())
      .filter(Boolean)
  )
)

// DEFAULT_CATEGORIES lideran siempre; las categorías extra se añaden después
// en el orden de la hoja, sin ordenar alfabéticamente.
const extraCategories = sheetCategories.filter(
  (cat) => !DEFAULT_CATEGORIES.includes(cat)
)
const categories = Array.from(new Set([...DEFAULT_CATEGORIES, ...extraCategories]))

const activeCategory = "MUNDIAL"
---

<!--
  Todo el SEO (title, description, canonical, OG, Twitter, Schema…)
  vive en Layout.astro. Aquí solo pasamos los props si esta página
  necesita valores distintos a los defaults del Layout.
-->
<Layout configs={configs}>
  <CategoryTabs categories={categories} active={activeCategory} />

  <main class="container" aria-label="Catálogo de productos Panini">
    <!-- H1 semántico para Google; invisible pero presente en el DOM -->
    <h1 class="sr-only">Álbumes y cromos Panini – {activeCategory}</h1>

    {configError && (
      <p class="notice notice--warn" role="alert">
        Aviso: no se cargaron las configuraciones ({configError})
      </p>
    )}

    {
      productosError ? (
        <p class="empty" role="alert">
          No se pudieron cargar los productos desde Google Sheets. Verifica el
          ID del documento en <code>src/content.config.ts</code> y que la hoja
          sea pública.
        </p>
      ) : productos.length === 0 ? (
        <p class="empty">Aún no hay productos en la hoja de cálculo.</p>
      ) : (
        <>
          <div class="grid">
            {productos.map((p) => (
              <ProductCard
                title={p.title}
                price={p.precio}
                description={p.description}
                image_link={p.imageLink}
                categories={p.categories ?? []}
              />
            ))}
          </div>
          <p class="empty" data-empty-category hidden>
            No hay productos en esta categoría.
          </p>
        </>
      )
    }
  </main>
</Layout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .notice {
    padding: 0.75rem 1rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
  }

  .notice--warn {
    background: #fef9c3;
    color: #713f12;
    border: 1px solid #fde047;
  }
</style>