---
// src/pages/blog/index.astro
import { getCollection } from 'astro:content';
import type { Config } from '../../lib/config-loader'; // Ajusta la ruta según tu estructura de proyecto
// Ajusta la ruta y el nombre del layout que ya tienes
import Layout from '../../layouts/Layout.astro'; // o donde esté tu layout

// Obtener todas las entradas del blog
const allPosts = await getCollection('blog');

// Ordenar de la más reciente a la más antigua
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

// Metadatos para el layout y la página
const pageTitle = "Blog";
const pageDescription = "Artículos, tutoriales y noticias sobre Tu Distribuidor Panini y más.";
let configs: Config = {} as Config;
let loadError: string | null = null;
try {
  const config = await getCollection("configuraciones");
  configs = config[0]?.data as Config;
} catch (err) {
  loadError = err instanceof Error ? err.message : "No se pudieron cargar las configuraciones.";
}
---

<Layout title={pageTitle} configs={configs} >
  <main class="prose">
    <h1>{pageTitle}</h1>
    <p>{pageDescription}</p>

    {posts.length === 0 ? (
      <p>No hay entradas aún. ¡Vuelve pronto!</p>
    ) : (
      <ul class="blog-grid">
        {posts.map((post) => (
          <li class="post-card">
            <a href={`/blog/${post.id}`} class="post-link">
              {post.data.image && (
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  loading="lazy"
                  decoding="async"
                />
              )}
              <h2 class="post-title">{post.data.title}</h2>
            </a>
            <p class="post-description">{post.data.description}</p>
            <div class="post-meta">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('es-CO', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              <span class="post-category">{post.data.category}</span>
            </div>
          </li>
        ))}
      </ul>
    )}
  </main>
</Layout>

<style>
  /* Estilos base (personaliza a tu gusto) */
  .blog-grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .post-card {
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    overflow: hidden;
    background: #fff;
    display: flex;
    flex-direction: column;
    padding: 1rem;
  }
  .post-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .post-link img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 0.25rem;
  }
  .post-title {
    margin: 0;
    font-size: 1.25rem;
    color: #1a202c;
  }
  .post-description {
    color: #4a5568;
    flex: 1;
  }
  .post-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.875rem;
    color: #718096;
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: 1px solid #edf2f7;
  }
  .post-category {
    background: #edf2f7;
    padding: 0.2rem 0.5rem;
    border-radius: 9999px;
    text-transform: uppercase;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }
</style>