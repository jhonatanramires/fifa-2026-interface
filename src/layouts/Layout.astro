---
import "../styles/global.css"
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import LayoutS from "../components/Schemas/LayoutS.astro"
import MerchantRate from "../components/MerchantRate.astro"
import type { Config } from "../lib/config-loader"
import "@fontsource/inter/400.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "@fontsource/inter/800.css";

interface Props {
  title?: string
  description?: string
  canonical?: string
  ogImage?: string
  configs: Config
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
  title       = "Distripanini – Distribuidora autorizada Panini en Colombia",
  description = "Compra álbumes, sobres y coleccionables Panini en Colombia. Copa Mundial FIFA 2026, Liga BetPlay y más. Envíos a todo el país desde Medellín. Centro Comercial City Plaza, Local 202.",
  canonical   = canonicalURL.toString(),
  ogImage     = "https://distripanini.com/og-image.jpg",
  configs,
} = Astro.props

---

<!doctype html>
<html lang="es" class="bg-background">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ── Título y descripción ─────────────────────────────────────────── -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- ── Indexación ───────────────────────────────────────────────────── -->
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />

    <!-- ── Idioma / región ──────────────────────────────────────────────── -->
    <link rel="alternate" hreflang="es-CO" href="https://distripanini.com/" />

    <!-- ── Geolocalización ──────────────────────────────────────────────── -->
    <meta name="geo.region"    content="CO-ANT" />
    <meta name="geo.placename" content="Medellín, Antioquia, Colombia" />
    <meta name="geo.position"  content="6.2442;-75.5812" />
    <meta name="ICBM"          content="6.2442, -75.5812" />

    <!-- ── Tema / PWA ───────────────────────────────────────────────────── -->
    <meta name="theme-color" content="#0050b3" />
    <link rel="icon"    href="/favicon.ico" type="image/x-icon" />
    <link rel="sitemap" href="/sitemap-0.xml" />

    <!-- ── Open Graph ───────────────────────────────────────────────────── -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonical} />
    <meta property="og:locale"      content="es_CO" />
    <meta property="og:site_name"   content="Distripanini" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:image:alt"   content="Distripanini – Distribuidora autorizada Panini en Colombia" />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- ── Twitter / X Card ─────────────────────────────────────────────── -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />
    <meta name="twitter:image:alt"   content="Distripanini – Distribuidora autorizada Panini en Colombia" />

    <!-- ── Datos estructurados (Schema.org) ─────────────────────────────── -->
    <LayoutS configs={configs} canonical={canonical} />

    <!-- ── Slot para meta adicional por página (opcional) ───────────────── -->
    <slot name="head" />
  </head>
  <body>
    <Header />
    <slot />
    <MerchantRate />
    <Footer configs={configs} />
  </body>
</html>