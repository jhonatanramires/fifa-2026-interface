---
import "../styles/global.css"
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import type { Config } from "../lib/config-loader"
import { Font } from "astro:assets"

interface Props {
  title?: string,
  configs: Config
}
const { title = "Panini — Tienda Oficial" , configs } = Astro.props
---

<!doctype html>
<html lang="es" class="bg-background">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0050b3" />
    <meta
      name="description"
      content="Tienda oficial Panini: álbumes, sobres y coleccionables de la Copa Mundial de la FIFA 2026."
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <Font cssVariable="--font-inter" preload />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <slot />
    <Footer configs={configs} />
  </body>
</html>
