---
import "../styles/global.css"
import Header from "../components/Header.astro"

interface Props {
  title?: string
}
const { title = "Panini — Tienda Oficial" } = Astro.props
---

<!doctype html>
<html lang="es" class="bg-background">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0050b3" />
    <meta
      name="description"
      content="Tienda oficial Panini: álbumes, sobres y coleccionables de la Copa Mundial de la FIFA 2026."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <slot />
  </body>
</html>
